{
  "version": 1,
  "gates": [
    {
      "id": "types",
      "label": "Typecheck (no emit)",
      "type": "command",
      "run": "npm run lint"
    },
    {
      "id": "unit",
      "label": "Self-tests for whitebox",
      "type": "command",
      "run": "npx vitest run"
    },
    {
      "id": "example-suite",
      "label": "Example app test suite",
      "type": "command",
      "cwd": "examples/todo-app",
      "run": "npm test"
    }
  ]
}
